# Matrix Manager beta runtime configuration

# Installer mode: sqlite | postgresql
MATRIX_INSTALL_MODE=sqlite
MATRIX_ACTIVE_DB_TYPE=sqlite

# App auth/runtime
MATRIX_AUTH_USERNAME=admin
MATRIX_AUTH_PASSWORD=change-me
MATRIX_AUTH_SECRET=replace-with-a-long-random-secret
MATRIX_APP_PORT=8000
MATRIX_BASE_URL=http://127.0.0.1:8000

# SQLite mode
MATRIX_SQLITE_PATH=/data/sqlite/matrix.db
MATRIX_CONTROL_DB_PATH=/data/app/matrixmanager_control.db

# PostgreSQL mode
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=matrixmanager
POSTGRES_USER=matrixmanager
POSTGRES_PASSWORD=change-me
POSTGRES_SSLMODE=prefer
